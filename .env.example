# ============================================
# Environment Variables
# ============================================
# Salin file ini menjadi .env.local dan isi dengan nilai yang benar

# ============================================
# Database PostgreSQL (Supabase)
# ============================================
# Dapatkan dari: Supabase Dashboard > Settings > Database
# Gunakan connection string dengan pooler untuk DATABASE_URL
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Gunakan direct connection untuk migrasi
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ============================================
# NextAuth.js
# ============================================
# Secret untuk enkripsi JWT - generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
# URL aplikasi (untuk development)
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# Cloudinary (Media Storage)
# ============================================
# Dapatkan dari: Cloudinary Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
